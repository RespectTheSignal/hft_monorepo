# QuestDB
QUESTDB_URL=http://localhost:9000
# 인증이 있으면: http://user:password@host:9000
QUESTDB_QUERY_TIMEOUT_SECS=120
# QUESTDB_MAX_GET_QUERY_LEN=7500
# QUESTDB_EXEC_USE_POST=0

# Redis
REDIS_URL=redis://localhost:6379

# Job 공통
UPDATE_INTERVAL_SECS=10
# 윈도우 분리 운영: fast / slow / all (default all). 두 데몬으로 분리 권장.
WINDOW_MODE=all
MARKET_GAP_REDIS_PREFIX=gate_hft:market_gap
MARKET_GAP_BASE=gate
MARKET_GAP_QUOTE_EXCHANGES=binance
MARKET_GAP_FILL_PREV_LOOKBACK_MINUTES=10

# Heartbeat 키: {prefix}:{mode} 에 cycle 결과 JSON SET
HEARTBEAT_REDIS_PREFIX=gate_hft:_meta:market_state_updater

# Telegram alert (token+chat_id 둘 다 있을 때만 활성)
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=
ALERT_AFTER_CONSECUTIVE_FAILURES=5

# Job toggles (1 = on, 0 = off)
MARKET_GAP_INCLUDE_GATE_WEB=1
MARKET_GAP_INCLUDE_GATE_SPREAD_PAIR=1
MARKET_GAP_INCLUDE_GATE_GATE_WEB_GAP=1
MARKET_GAP_INCLUDE_PRICE_CHANGE=1
MARKET_GAP_INCLUDE_PRICE_CHANGE_GAP_CORR=1

# price_change job
PRICE_CHANGE_REDIS_PREFIX=gate_hft:price_change
PRICE_CHANGE_SOURCES=gate,binance

# price_change_gap_corr job (gate_web price-change ↔ gate_web↔quote gap)
CORR_QUOTE_EXCHANGES=binance
# 윈도우별 X return interval (초). 비어있으면 DEFAULT_CORR_RETURN_SECONDS 사용.
# 예: CORR_RETURN_SECONDS_OVERRIDES=60:60,240:120
CORR_RETURN_SECONDS_OVERRIDES=
