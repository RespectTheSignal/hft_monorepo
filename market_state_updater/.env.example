# market_state_updater secret-only env.
# 비-secret 모든 설정은 config.json 에. 일회성 override 는 여기에 (env > config.json).

# DB / cache (auth 정보 포함되니 .env 에)
QUESTDB_URL=http://localhost:9000
# 인증이 있으면: http://user:password@host:9000
REDIS_URL=redis://localhost:6379

# Telegram alert (둘 다 set 되면 활성, 하나라도 비면 no-op)
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=

# 일회성 override 예시 (보통 안 씀, config.json 우선)
# UPDATE_INTERVAL_SECS=1     # tick poll interval (default 1s). cadence 자체는 schedule 별
# WINDOW_MODE=fast
# CADENCE_OVERRIDES_SECS=1:5,5:25,60:120
# MARKET_GAP_INCLUDE_PRICE_CHANGE_GAP_CORR=0
# MARKET_GAP_INCLUDE_MID_CORR=0
# MID_CORR_QUOTE_EXCHANGES=binance,bybit
# MID_CORR_MIN_SAMPLES=30
# MARKET_GAP_INCLUDE_RETURN_AUTOCORR=0
# RETURN_AUTOCORR_EXCHANGES=gate,gate_web,binance
# RETURN_AUTOCORR_MIN_SAMPLES=30
# CORR_RETURN_SECONDS_OVERRIDES=60:60,240:120
# MARKET_GAP_SAMPLE_INTERVAL_OVERRIDES=1:100T,5:200T,60:1s
