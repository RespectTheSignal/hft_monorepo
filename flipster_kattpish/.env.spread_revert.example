# spread_revert strategy — example env
# Copy to .env (or `set -a; source this; set +a` before running collector).
# Keep this file out of git. Mode 600.
#
# Strategy: Binance↔Flipster mid-gap mean reversion (Jay's spec).
# Reads avg_gap / avg_spread from baseline_writer's SharedBaselines map
# (refreshed every 5 s from QuestDB matched-bucket JOINs).

# ============================================================
# Required infrastructure
# ============================================================

# Enable spread_revert task. Off by default in main.rs.
SPREAD_REVERT=1

# spread_revert lives inside the PAPER_BOT branch in bin/main.rs.
# Must be 1 even for live mode (the signal goes out via ZMQ → executor).
PAPER_BOT=1

# Direct ZMQ SUB feeds (instead of WS subscribers / QuestDB poller).
USE_ZMQ=1

# Don't dual-write tick rows when the upstream feed already populates
# binance_bookticker / flipster_bookticker. Position_log writes are
# unaffected.
DISABLE_TICK_WRITES=1

# Disable other paper bots so spread_revert is the only strategy in this
# process. Set to 1 if you want pairs variants alongside.
PAPER_VARIANTS=0
GATE_LEAD=0

# QuestDB (ILP for writes, HTTP for baseline_writer queries).
QDB_HOST=211.181.122.102
QDB_ILP_PORT=9009
QUESTDB_HTTP_URL=http://211.181.122.102:9000

# Optional — overrides QUESTDB_HTTP_URL for baseline_writer only.
# BASELINE_QDB_HTTP=http://211.181.122.102:9000
# BASELINE_INTERVAL_S=5

# ZMQ tick sources (defaults shown — override only if topology changes).
# ZMQ_FLIPSTER=tcp://211.181.122.104:7000
# ZMQ_BINANCE=tcp://211.181.122.24:6000
# ZMQ_GATE=tcp://211.181.122.24:5559

# ZMQ PUB for trade_signal (consumed by executor). Use a unique port if
# running alongside another collector instance.
SIGNAL_PUB_ADDR=tcp://127.0.0.1:7501

# Logging.
RUST_LOG=info

# ============================================================
# spread_revert parameters (SR_*)
# ============================================================

# Tag rows in position_log with this account_id. Use a distinct value
# for paper vs live so QuestDB filters separate them.
SR_ACCOUNT_ID=SPREAD_REVERT_v1_paper

# USD notional per trade (fixed-size).
SR_SIZE_USD=10

# Global concurrent position cap (across all bases). Safety ceiling —
# per-base cap below is the normal constraint.
SR_MAX_POSITIONS=50

# Per-symbol stack cap (Jay's spec: max 5 simultaneous on same coin).
SR_MAX_POSITIONS_PER_BASE=5

# Extra bp required on top of measured costs to trigger entry.
# costs = avg_flipster_spread + avg_binance_spread/2 + flipster_fee_bp
# Entry condition: |current_gap − bf_avg_gap| > costs + entry_threshold.
SR_ENTRY_BP=2.0

# Stop-loss: close when Flipster mid moves SR_STOP_BP adversely from the
# entry price (single-leg, expressed in bp).
SR_STOP_BP=20

# Hard timeout (seconds). Past this the position closes with
# reason="timeout", separate from price-stop. Default 24 h.
SR_MAX_HOLD_S=86400

# Minimum hold time after entry (ms). Stop-loss + reverse-close are
# blocked until this window passes — prevents instant flap-out on tick
# noise right after entry. Timeout (above) is unaffected.
# Default 0 (no minimum).
SR_MIN_HOLD_MS=0

# Per-base re-entry cooldown (ms). Prevents a flapping signal from
# firing two consecutive entries on the same symbol.
SR_ENTRY_COOLDOWN_MS=500

# Per-side Flipster taker fee (bp). Used inside the entry edge calc and
# the close PnL net calculation (×2 for round-trip).
SR_FEE_BP=0.425

# Whitelist (comma-separated bases, uppercase). Empty = allow all
# (filtered by blacklist).
# SR_WHITELIST=BTC,ETH,SOL,XRP

# Blacklist (always applied, overrides whitelist). Defaults to known
# bad-edge symbols.
SR_BLACKLIST=M,BSB,SWARMS,ORCA
